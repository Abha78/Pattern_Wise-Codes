class Solution {
    public static boolean isPerfect(int[] arr) {
        // code here
        int left =0;
        int right = arr.length-1;
        
        while(left<right){
            
            if(arr[left++]!=arr[right--]){
                // left++;
                // right--;
                return false;
            }
           
        }
        return true;
    }
}
