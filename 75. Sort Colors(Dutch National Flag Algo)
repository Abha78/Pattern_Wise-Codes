class Solution {
    public void sortColors(int[] nums) {

        int low = 0; 
        int mid = 0;
        int high = nums.length-1;
        while(mid<=high){

            //Case 0
            if(nums[mid]==0){
                swap(nums,low,mid);
                mid++;
                low++;
            }
            // Case 1
            else if(nums[mid]==1){
                mid++;
            }
            //Case 2 
           else { 
            //(nums[mid]==2)
                swap(nums,high,mid);
                high--;
                //mid will not increase in this case
            }
        }
    }
        private void swap(int[]nums, int i, int j){
            int temp = nums[i];
            nums[i] = nums[j];
            nums[j] = temp;

        }
        
    }
